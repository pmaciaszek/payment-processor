<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2-create-user-device-table" author="pmaciaszek">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="user_devices"/>
            </not>
        </preConditions>
        <createTable tableName="user_devices">
            <column name="user_id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="device_id" type="TEXT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="trusted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="user_devices"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                onDelete="CASCADE"
                constraintName="fk_user_devices"/>
        <createIndex tableName="user_devices" indexName="idx_user_devices_user_id">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>