<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

    <appender name="advancedJsonAppender" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <jsonGeneratorDecorator class="net.logstash.logback.mask.MaskingJsonGeneratorDecorator">
                <defaultMask>********</defaultMask>

                <!-- authorization headers & parameters -->
                <path>*/authorization</path>
                <path>*/Authorization</path>
                <path>*/token</path>

                <valueMask>
                    <value>^(tok_\w{3})(\w{7})$</value>
                    <mask>*********$1</mask>
                </valueMask>

                <!-- emails -->
                <valueMask>
                    <value>(\w{3})([\w\.]*?)(@[\w\.]*?)</value>
                    <mask>$1********$3</mask>
                </valueMask>
            </jsonGeneratorDecorator>

            <providers>
                <timestamp/>
                <logLevel/>
                <message/>
                <mdc/>
                <arguments/>
                <version/>
                <loggerName/>
                <logLevelValue/>
                <threadName/>
                <stackTrace/>
            </providers>
        </encoder>
    </appender>

    <appender name="stdoutConsoleAppender" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %highlight(%-5level) %logger{36} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <springProfile name="!test &amp; !local">
        <root level="INFO">
            <appender-ref ref="advancedJsonAppender"/>
        </root>
    </springProfile>

    <springProfile name="test | local">
        <root level="INFO">
            <appender-ref ref="stdoutConsoleAppender"/>
        </root>
    </springProfile>
</configuration>
